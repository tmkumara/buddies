# Database (MariaDB / MySQL connection string)
DATABASE_URL="mysql://user:password@localhost:3306/giftbox_oms"

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Resend (email notifications)
# Get your API key at https://resend.com/api-keys
# NOTE: The sandbox sender (onboarding@resend.dev) only delivers to the Resend account owner's
# email address. To send to real customer addresses, verify your own domain at
# https://resend.com/domains and set RESEND_FROM_EMAIL to a verified address.
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Buddies <hello@your-verified-domain.com>
